# Configuration type pour l'API publique `https://api.axelys.app`

# Base locale par defaut (alignee avec docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/immo_ops?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/immo_ops?schema=public"

# JWT de production
JWT_SECRET="replace-with-a-long-random-secret"

# URL publique de l'application web, utilisee pour les emails utilisateur
APP_WEB_URL="https://app.axelys.app"

# Origines autorisees en CORS pour le navigateur
ALLOWED_ORIGINS="https://app.axelys.app,https://axelys.app,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3001,http://127.0.0.1:3001"

# Duree de validite d'un lien d'invitation admin
USER_INVITATION_TTL_HOURS=72

# Expediteur transactionnel et boite de notification pilote
MAIL_FROM="Axelys <no-reply@axelys.app>"
PILOT_NOTIFICATION_EMAIL="contact@axelys.app"

# Provider email optionnel (Resend). Sans ces variables, l'API loggue l'email localement.
RESEND_API_KEY="re_replace_me"

SMTP_HOST="smtp.example.com"
SMTP_PORT=465
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
SMTP_SECURE=true
