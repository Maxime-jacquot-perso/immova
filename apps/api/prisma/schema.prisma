generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MembershipRole {
  ADMIN
  MANAGER
  ACCOUNTANT
  READER
}

enum ProjectType {
  APARTMENT_BUILDING
  HOUSE
  MIXED
  COMMERCIAL
  OTHER
}

enum ProjectStatus {
  DRAFT
  ACQUISITION
  WORKS
  READY
  ACTIVE
  SOLD
  ARCHIVED
}

enum LotType {
  APARTMENT
  HOUSE
  GARAGE
  CELLAR
  OFFICE
  SHOP
  OTHER
}

enum LotStatus {
  DRAFT
  AVAILABLE
  RENTED
  SOLD
  ARCHIVED
}

enum ExpenseCategory {
  ACQUISITION
  WORKS
  TAX
  INSURANCE
  UTILITIES
  MANAGEMENT
  LEGAL
  MAINTENANCE
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
}

enum DocumentType {
  INVOICE
  QUOTE
  CONTRACT
  DIAGNOSTIC
  PHOTO
  PLAN
  INSURANCE
  OTHER
}

enum AdminRole {
  USER
  SUPER_ADMIN
  ADMIN
  SALES_ADMIN
  SUPPORT_ADMIN
  READONLY_ADMIN
}

enum InvitationOrganizationMode {
  EXISTING
  PERSONAL
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  NONE
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum FeatureRequestStatus {
  OPEN
  PLANNED
  IN_PROGRESS
  DONE
  REJECTED
}

enum AdminAuditAction {
  TRIAL_GRANTED
  TRIAL_EXTENDED
  USER_SUSPENDED
  USER_REACTIVATED
  SUBSCRIPTION_UPDATED
  ADMIN_CREATED
  ADMIN_ROLE_CHANGED
  USER_INVITED
  USER_INVITE_RESENT
  USER_PILOT_ACCESS_UPDATED
  FEATURE_REQUEST_STATUS_UPDATED
}

enum AdminAuditTargetType {
  USER
  ADMIN
  SUBSCRIPTION
  FEATURE_REQUEST
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships                    Membership[]
  projects                       Project[]
  lots                           Lot[]
  expenses                       Expense[]
  documents                      Document[]
  userInvitations                UserInvitation[]
  featureRequests                FeatureRequest[]
  featureRequestVotes            FeatureRequestVote[]
  simulationFolders              SimulationFolder[]
  simulations                    Simulation[]
  simulationLots                 SimulationLot[]
  simulationWorkItems            SimulationWorkItem[]
  workItemOptions                WorkItemOption[]
  opportunityEvents              OpportunityEvent[]
  simulationOptionGroups         SimulationOptionGroup[]
  simulationOptions              SimulationOption[]
  simulationOptionActivationLogs SimulationOptionActivationLog[]
}

model User {
  id                   String             @id @default(cuid())
  email                String             @unique
  firstName            String?
  lastName             String?
  passwordHash         String?
  adminRole            AdminRole          @default(USER)
  isSuspended          Boolean            @default(false)
  isPilotUser          Boolean            @default(false)
  betaAccessEnabled    Boolean            @default(false)
  trialEndsAt          DateTime?
  trialExtensionsCount Int                @default(0)
  subscriptionPlan     SubscriptionPlan   @default(FREE)
  subscriptionStatus   SubscriptionStatus @default(NONE)
  lastLoginAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  memberships         Membership[]
  adminAuditEntries   AdminAuditLog[]      @relation("AdminAuditActor")
  adminAuditTargets   AdminAuditLog[]      @relation("AdminAuditTarget")
  invitations         UserInvitation[]     @relation("InvitationUser")
  createdInvitations  UserInvitation[]     @relation("InvitationCreator")
  featureRequests     FeatureRequest[]     @relation("FeatureRequestAuthor")
  featureRequestVotes FeatureRequestVote[]

  @@index([adminRole])
  @@index([isSuspended, subscriptionStatus])
  @@index([isPilotUser, betaAccessEnabled])
  @@index([subscriptionPlan])
  @@index([trialEndsAt])
}

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId, role])
}

model UserInvitation {
  id                   String                     @id @default(cuid())
  email                String
  userId               String?
  organizationMode     InvitationOrganizationMode @default(EXISTING)
  organizationId       String?
  membershipRole       MembershipRole
  tokenHash            String                     @unique
  expiresAt            DateTime
  acceptedAt           DateTime?
  revokedAt            DateTime?
  createdByAdminUserId String
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  user               User?         @relation("InvitationUser", fields: [userId], references: [id], onDelete: SetNull)
  organization       Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByAdminUser User          @relation("InvitationCreator", fields: [createdByAdminUserId], references: [id], onDelete: Restrict)

  @@index([email])
  @@index([userId, organizationId])
  @@index([organizationId, expiresAt])
  @@index([createdByAdminUserId, createdAt])
}

model Project {
  id              String        @id @default(cuid())
  organizationId  String
  name            String
  reference       String?
  addressLine1    String?
  postalCode      String?
  city            String?
  country         String        @default("FR")
  type            ProjectType   @default(OTHER)
  status          ProjectStatus @default(DRAFT)
  purchasePrice   Decimal?      @db.Decimal(12, 2)
  notaryFees      Decimal?      @db.Decimal(12, 2)
  acquisitionFees Decimal?      @db.Decimal(12, 2)
  worksBudget     Decimal?      @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lots                    Lot[]
  expenses                Expense[]
  documents               Document[]
  convertedFromSimulation Simulation[] @relation("SimulationConvertedProject")

  @@index([organizationId, status])
}

model Lot {
  id             String    @id @default(cuid())
  organizationId String
  projectId      String
  name           String
  reference      String?
  type           LotType   @default(OTHER)
  status         LotStatus @default(DRAFT)
  surface        Decimal?  @db.Decimal(10, 2)
  estimatedRent  Decimal?  @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expenses     Expense[]

  @@index([organizationId, projectId, status])
}

model Expense {
  id             String          @id @default(cuid())
  organizationId String
  projectId      String
  lotId          String?
  invoiceNumber  String?
  issueDate      DateTime
  amountHt       Decimal         @db.Decimal(12, 2)
  vatAmount      Decimal         @db.Decimal(12, 2)
  amountTtc      Decimal         @db.Decimal(12, 2)
  category       ExpenseCategory
  paymentStatus  PaymentStatus   @default(PENDING)
  vendorName     String?
  comment        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lot          Lot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)
  documents    Document[]

  @@index([organizationId, projectId, category, paymentStatus])
}

model Document {
  id               String       @id @default(cuid())
  organizationId   String
  projectId        String
  expenseId        String?
  type             DocumentType @default(OTHER)
  title            String
  originalFileName String
  storageKey       String       @unique
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expense      Expense?     @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  @@index([organizationId, projectId, type])
}

model AdminAuditLog {
  id           String               @id @default(cuid())
  actorUserId  String
  targetUserId String?
  action       AdminAuditAction
  targetType   AdminAuditTargetType
  reason       String
  oldValue     Json?
  newValue     Json?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime             @default(now())

  actorUser  User  @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  targetUser User? @relation("AdminAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([action, createdAt])
}

model FeatureRequest {
  id             String               @id @default(cuid())
  organizationId String
  authorId       String
  title          String
  description    String
  votesCount     Int                  @default(0)
  status         FeatureRequestStatus @default(OPEN)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User                 @relation("FeatureRequestAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  votes        FeatureRequestVote[]

  @@index([organizationId, status, createdAt])
  @@index([organizationId, votesCount, createdAt])
  @@index([authorId, createdAt])
}

model FeatureRequestVote {
  id               String   @id @default(cuid())
  organizationId   String
  userId           String
  featureRequestId String
  createdAt        DateTime @default(now())

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@unique([featureRequestId, userId])
  @@index([organizationId, featureRequestId])
  @@index([organizationId, userId])
}

enum SimulationStrategy {
  FLIP
  RENTAL
}

enum SimulationPropertyType {
  ANCIEN
  NEUF_VEFA
}

enum FinancingMode {
  CASH
  LOAN
}

enum DecisionStatus {
  GOOD
  REVIEW
  RISKY
}

enum SimulationLotType {
  APARTMENT
  GARAGE
  CELLAR
  OTHER
}

enum OpportunityEventType {
  NEGOTIATION_PRICE
  BANK_FINANCING_QUOTE
  VISIT_NOTE
  RISK_ALERT
  ASSUMPTION_CHANGE
  OTHER
}

enum OptionStatus {
  ACTIVE
  CANDIDATE
}

enum SimulationOptionGroupType {
  PURCHASE_PRICE
  WORK_BUDGET
  FINANCING
}

enum SimulationOptionSource {
  MANUAL
  FROM_EVENT
}

model SimulationFolder {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  simulations  Simulation[]

  @@index([organizationId, archivedAt])
}

model Simulation {
  id                             String             @id @default(cuid())
  organizationId                 String
  folderId                       String
  name                           String
  address                        String?
  strategy                       SimulationStrategy
  propertyType                   SimulationPropertyType?
  departmentCode                 String?            @db.VarChar(3)
  isFirstTimeBuyer               Boolean            @default(false)
  purchasePrice                  Decimal            @db.Decimal(12, 2)
  furnitureValue                 Decimal?           @db.Decimal(12, 2)
  estimatedDisbursements         Decimal?           @db.Decimal(12, 2)
  notaryFees                     Decimal?           @db.Decimal(12, 2)
  notaryFeesBreakdown            Json?
  acquisitionFees                Decimal            @db.Decimal(12, 2)
  worksBudget                    Decimal            @db.Decimal(12, 2)
  worksBreakdownJson             Json?
  financingMode                  FinancingMode
  downPayment                    Decimal?           @db.Decimal(12, 2)
  loanAmount                     Decimal?           @db.Decimal(12, 2)
  interestRate                   Decimal?           @db.Decimal(5, 2)
  loanDurationMonths             Int?
  estimatedMonthlyPayment        Decimal?           @db.Decimal(10, 2)
  estimatedProjectDurationMonths Int?
  targetResalePrice              Decimal?           @db.Decimal(12, 2)
  targetMonthlyRent              Decimal?           @db.Decimal(10, 2)
  bufferAmount                   Decimal?           @db.Decimal(12, 2)
  notes                          String?
  decisionScore                  Int?
  decisionStatus                 DecisionStatus?
  resultSummaryJson              Json?
  convertedProjectId             String?
  archivedAt                     DateTime?
  createdAt                      DateTime           @default(now())
  updatedAt                      DateTime           @updatedAt

  organization         Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  folder               SimulationFolder                @relation(fields: [folderId], references: [id], onDelete: Cascade)
  convertedProject     Project?                        @relation("SimulationConvertedProject", fields: [convertedProjectId], references: [id], onDelete: SetNull)
  lots                 SimulationLot[]
  workItems            SimulationWorkItem[]
  events               OpportunityEvent[]              @relation("SimulationEvents")
  optionGroups         SimulationOptionGroup[]
  optionActivationLogs SimulationOptionActivationLog[]

  @@index([organizationId, folderId, archivedAt])
  @@index([organizationId, strategy, decisionStatus])
  @@index([convertedProjectId])
}

model SimulationLot {
  id                String            @id @default(cuid())
  organizationId    String
  simulationId      String
  name              String
  type              SimulationLotType @default(OTHER)
  surface           Decimal?          @db.Decimal(10, 2)
  estimatedRent     Decimal?          @db.Decimal(10, 2)
  targetResaleValue Decimal?          @db.Decimal(12, 2)
  notes             String?
  position          Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  simulation   Simulation   @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@index([organizationId, simulationId, position])
}

model OpportunityEvent {
  id             String               @id @default(cuid())
  organizationId String
  simulationId   String
  type           OpportunityEventType
  title          String
  description    String?
  eventDate      DateTime
  impact         String?
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  simulation     Simulation         @relation("SimulationEvents", fields: [simulationId], references: [id], onDelete: Cascade)
  relatedOptions SimulationOption[] @relation("EventOptions")

  @@index([organizationId, simulationId, eventDate])
}

model SimulationOptionGroup {
  id             String                    @id @default(cuid())
  organizationId String
  simulationId   String
  type           SimulationOptionGroupType
  label          String
  activeOptionId String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  organization   Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  simulation     Simulation                      @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  activeOption   SimulationOption?               @relation("ActiveOption", fields: [activeOptionId], references: [id], onDelete: SetNull)
  options        SimulationOption[]              @relation("GroupOptions")
  activationLogs SimulationOptionActivationLog[]

  @@unique([simulationId, type])
  @@index([organizationId, simulationId])
}

model SimulationOptionActivationLog {
  id                String   @id @default(cuid())
  organizationId    String
  simulationId      String
  optionGroupId     String
  previousOptionId  String?
  newOptionId       String
  activatedByUserId String
  createdAt         DateTime @default(now())

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  simulation   Simulation            @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  optionGroup  SimulationOptionGroup @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)

  @@index([organizationId, simulationId, createdAt])
  @@index([optionGroupId, createdAt])
  @@index([activatedByUserId, createdAt])
}

model SimulationOption {
  id             String                 @id @default(cuid())
  organizationId String
  groupId        String
  label          String
  valueJson      Json
  isActive       Boolean                @default(false)
  source         SimulationOptionSource @default(MANUAL)
  sourceEventId  String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group          SimulationOptionGroup   @relation("GroupOptions", fields: [groupId], references: [id], onDelete: Cascade)
  sourceEvent    OpportunityEvent?       @relation("EventOptions", fields: [sourceEventId], references: [id], onDelete: SetNull)
  activeInGroups SimulationOptionGroup[] @relation("ActiveOption")

  @@index([organizationId, groupId])
  @@index([groupId, isActive])
  @@index([sourceEventId])
}

model SimulationWorkItem {
  id                    String   @id @default(cuid())
  organizationId        String
  simulationId          String
  name                  String
  initialCost           Decimal  @db.Decimal(12, 2)
  estimatedDurationDays Int?
  position              Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  simulation   Simulation       @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  options      WorkItemOption[]

  @@index([organizationId, simulationId, position])
}

model WorkItemOption {
  id             String       @id @default(cuid())
  organizationId String
  workItemId     String
  providerName   String
  cost           Decimal      @db.Decimal(12, 2)
  durationDays   Int?
  notes          String?
  status         OptionStatus @default(CANDIDATE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workItem     SimulationWorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([organizationId, workItemId, status])
}
